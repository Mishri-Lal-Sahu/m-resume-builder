generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Separate Admin table (no shared session with User) ───
model Admin {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Platform-wide settings (singleton, AES-256 encrypted sensitive fields) ───
model AdminSettings {
  id                      String   @id @default(cuid())
  // SMTP config (smtpPassEncrypted stored as AES-256-GCM ciphertext:iv:authTag)
  smtpHost                String?
  smtpPort                Int?
  smtpUser                String?
  smtpPassEncrypted       String?  @db.Text
  smtpFrom                String?
  // User & document limits
  maxDocsPerUser          Int      @default(10)
  maxPagesPerDoc          Int      @default(50)
  maxCollaboratorsPerDoc  Int      @default(5)
  updatedAt               DateTime @updatedAt
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole      @default(USER)
  country       String?
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  activityLogs  ActivityLog[]
  resumes       Resume[]
  sessions      Session[]
  docInvitesSent      DocInvitation[] @relation("DocInvitedBy")
  docInvitesAccepted  DocInvitation[] @relation("DocAcceptedBy")
  docComments         DocComment[]
}

model Resume {
  id              String           @id @default(cuid())
  userId          String?
  title           String
  slug            String?          @unique
  templateKey     String
  visibility      ResumeVisibility @default(PRIVATE)
  passwordHash    String?
  profilePhotoUrl String?
  content         Json
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rawContent      Json?
  activityLogs    ActivityLog[]
  user            User?            @relation(fields: [userId], references: [id])
  shareLinks      ResumeShare[]
  docInvitations  DocInvitation[]
  docComments     DocComment[]

  @@index([userId, updatedAt])
  @@index([visibility])
}

model DocInvitation {
  id           String              @id @default(cuid())
  resumeId     String
  email        String
  token        String              @unique
  status       DocInvitationStatus @default(PENDING)
  invitedById  String
  invitedUserId String?
  acceptedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  resume       Resume              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  invitedBy    User                @relation("DocInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUser  User?               @relation("DocAcceptedBy", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([resumeId, status])
  @@index([email, status])
}

model DocComment {
  id        String   @id @default(cuid())
  resumeId  String
  authorId  String
  parentId  String?
  reference String   @db.VarChar(500)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    DocComment? @relation("DocCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   DocComment[] @relation("DocCommentReplies")

  @@index([resumeId, createdAt])
  @@index([resumeId, parentId, createdAt])
}

model ResumeShare {
  id           String           @id @default(cuid())
  resumeId     String
  shareToken   String           @unique
  visibility   ResumeVisibility @default(LINK_ONLY)
  passwordHash String?
  expiresAt    DateTime?
  createdAt    DateTime         @default(now())
  resume       Resume           @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model ActivityLog {
  id        String    @id @default(cuid())
  userId    String?
  resumeId  String?
  action    LogAction
  ipAddress String?
  country   String?
  metadata  Json?
  createdAt DateTime  @default(now())
  resume    Resume?   @relation(fields: [resumeId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([resumeId, createdAt])
  @@index([action, createdAt])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  USER
  ADMIN
}

enum ResumeVisibility {
  PRIVATE
  LINK_ONLY
  PUBLIC
}

enum LogAction {
  LOGIN
  RESUME_CREATE
  RESUME_EDIT
  EXPORT_PDF
  EXPORT_DOCX
  ANONYMOUS_USAGE
}

enum DocInvitationStatus {
  PENDING
  ACCEPTED
  WITHDRAWN
  REVOKED
  DECLINED
  EXPIRED
}
